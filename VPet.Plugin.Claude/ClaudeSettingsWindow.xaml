<Window x:Class="VPet.Plugin.Claude.ClaudeSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude AI Settings" 
        Height="580" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF5F5F5">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Claude AI Configuration" 
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,15"
                   Foreground="#FF6B3FA0"/>

        <!-- API Key -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Anthropic API Key:" FontWeight="SemiBold"/>
            <TextBlock Text="Get yours at console.anthropic.com" FontSize="11" Foreground="Gray" Margin="0,2,0,4"/>
            <PasswordBox x:Name="txtApiKey" Height="28" Padding="4,2"/>
        </StackPanel>

        <!-- Model -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Model:" FontWeight="SemiBold"/>
            <ComboBox x:Name="cmbModel" Height="28" IsEditable="True" Padding="4,2">
                <ComboBoxItem Content="claude-sonnet-4-6"/>
                <ComboBoxItem Content="claude-haiku-4-5-20251001"/>
                <ComboBoxItem Content="claude-opus-4-6"/>
            </ComboBox>
        </StackPanel>

        <!-- Custom API URL -->
        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Custom API URL (optional):" FontWeight="SemiBold"/>
            <TextBlock Text="Leave empty to use default Anthropic API" FontSize="11" Foreground="Gray" Margin="0,2,0,4"/>
            <TextBox x:Name="txtApiUrl" Height="28" Padding="4,2"/>
        </StackPanel>

        <!-- Max Tokens -->
        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Max Tokens:" FontWeight="SemiBold"/>
                <TextBox x:Name="txtMaxTokens" Height="28" Padding="4,2"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Text="History Messages:" FontWeight="SemiBold"/>
                <TextBox x:Name="txtMaxHistory" Height="28" Padding="4,2"/>
            </StackPanel>
        </Grid>

        <!-- Streaming Toggle -->
        <CheckBox Grid.Row="5" x:Name="chkStreaming" 
                  Content="Enable streaming responses" 
                  Margin="0,0,0,10" FontWeight="SemiBold"/>

        <!-- System Prompt -->
        <StackPanel Grid.Row="6" Margin="0,0,0,5">
            <TextBlock Text="System Prompt (pet personality):" FontWeight="SemiBold"/>
            <TextBlock Text="Defines how your pet talks. Leave empty for default." 
                       FontSize="11" Foreground="Gray" Margin="0,2,0,4"/>
        </StackPanel>
        
        <TextBox Grid.Row="7" x:Name="txtSystemPrompt" 
                 AcceptsReturn="True" TextWrapping="Wrap" 
                 VerticalScrollBarVisibility="Auto"
                 Padding="4" Margin="0,0,0,10"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button x:Name="btnClearHistory" Content="Clear Chat History" 
                    Width="130" Height="30" Margin="0,0,10,0"
                    Click="BtnClearHistory_Click"/>
            <Button x:Name="btnSave" Content="Save" 
                    Width="80" Height="30" Margin="0,0,10,0"
                    Click="BtnSave_Click" FontWeight="SemiBold"
                    Background="#FF6B3FA0" Foreground="White"/>
            <Button x:Name="btnCancel" Content="Cancel" 
                    Width="80" Height="30"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
