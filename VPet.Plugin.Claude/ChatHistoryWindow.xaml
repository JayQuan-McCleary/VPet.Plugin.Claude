<Window x:Class="VPet.Plugin.Claude.ChatHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chat History"
        Height="560" Width="620"
        WindowStartupLocation="CenterScreen"
        Background="#FFF5F5F5">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Chat History"
                   FontSize="18" FontWeight="Bold"
                   Foreground="#FF3F7FA0" Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1" x:Name="txtHistoryPath"
                   FontSize="11" Foreground="Gray"
                   TextWrapping="Wrap" Margin="0,0,0,10"/>

        <Border Grid.Row="2" BorderBrush="#FFCCCCCC" BorderThickness="1"
                Background="White" CornerRadius="2">
            <ScrollViewer x:Name="scrollViewer" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Padding="8">
                <ItemsControl x:Name="lstMessages">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,4" Padding="10,8" CornerRadius="4"
                                    Background="{Binding BubbleColor}">
                                <StackPanel>
                                    <TextBlock Text="{Binding RoleDisplay}"
                                               FontWeight="Bold" FontSize="11"
                                               Foreground="{Binding RoleColor}"
                                               Margin="0,0,0,3"/>
                                    <TextBlock Text="{Binding Content}"
                                               TextWrapping="Wrap" FontSize="13"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="btnExport" Content="Export to .txt..."
                    Width="120" Height="30" Margin="0,0,8,0"
                    Click="BtnExport_Click"/>
            <Button x:Name="btnOpenFolder" Content="Open Folder"
                    Width="100" Height="30" Margin="0,0,8,0"
                    Click="BtnOpenFolder_Click"/>
            <Button x:Name="btnClose" Content="Close"
                    Width="80" Height="30"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
